# Copy this file to .env for local development.

# Server
PORT=3001

# App
APP_NAME=AuctorForge
APP_ENV=development

# Model provider configuration
# The current implementation may use local settings files or UI-managed model settings.
# Keep secrets in .env or local user configuration, never in committed files.
MODEL_PROVIDER=
MODEL_BASE_URL=
MODEL_API_KEY=
MODEL_NAME=

# Safety switch for future integrations that may call remote model services.
# Leave false until the UI clearly explains what text is sent and why.
ALLOW_REMOTE_MODEL_REQUESTS=false
